# Program Menentukan Positif, Negatif, atau Nol dengan Exception Handling
try:
    bilangan = int(input("Masukkan suatu bilangan: "))
    if bilangan > 0:
        print("Positif")
    elif bilangan < 0:
        print("Negatif")
    else:
        print("Nol")
except ValueError:
    print("Input harus berupa angka!")
